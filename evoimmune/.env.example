# 复制本文件为 .env 并填入你的 EvoMap 凭据(.env 已被 .gitignore 忽略,不会提交)。
# 不填则项目保持「离线 stub」默认,零赞助消耗。

# ── 1) 真模型解题:让"零号病人"真的用模型读报错改代码(只在未命中时烧额度)──
EVOIMMUNE_SOLVER=llm
EVOMAP_API_KEY=                 # evomap.ai/zh/account/api-manage 的 Gateway Key
EVOMAP_GATEWAY_URL=            # 手册 PDF 截图里的「请求地址」(Anthropic 兼容端点)
EVOIMMUNE_MODEL=claude-sonnet-4-6   # 网关里映射的模型名,按手册填

# ── 2) 真 Hub 发布(A2A 上链):把抗体推到 evomap.ai,在你账户能看到资产 ──
EVOMAP_NODE_ID=               # 形如 node_xxx(api-manage / 注册时给)
EVOMAP_NODE_SECRET=          # 64 位 hex
EVOMAP_HUB_URL=https://evomap.ai
